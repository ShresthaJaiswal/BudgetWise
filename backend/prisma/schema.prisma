generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id               Int           @id @default(autoincrement())
  name             String
  email            String        @unique
  phone            String?       // optional, ? means nullable
  password         String
  currency         String        @default("INR")
  createdAt        DateTime      @default(now())  @map("created_at")
  updatedAt        DateTime      @updatedAt  @map("updated_at")
  transactions     transactions[]
  groups           group[]
}

model transactions {
  id              Int        @id @default(autoincrement())
  createdAt       DateTime   @default(now())  @map("created_at")
  createdBy       Int        @map("created_by")  // stores user_id of who created it
  updatedAt       DateTime   @updatedAt  @map("updated_at")
  updatedBy       Int        @map("updated_by")  // stores user_id of who last updated it
  description     String
  amount          Float

  user_id         Int
  type_id         Int
  category_id     Int

  status          Int        @default(1)

  user            user                  @relation(fields: [user_id], references: [id])  // just a relation for foreign key
  type            transaction_type      @relation(fields: [type_id], references: [id])
  category        transaction_category  @relation(fields: [category_id], references: [id])
  groups          group_transaction[]

  @@index([type_id])
  @@index([category_id])  // But right now your type/category filtering happens in useBudget on the frontend via useMemo — not in the database query. So those indexes are essentially unused at the moment.
  @@index([user_id, status])  // Composite Index - every transaction fetch filters by these two columns together. PostgreSQL can use this index to instantly narrow down to "all active transactions for this user" without scanning the whole table.
}

model transaction_type {
  id              Int           @id @default(autoincrement())
  name            String        @unique  // 'income' or 'expense'
  created_at      DateTime      @default(now())
  status          Int           @default(1)
  transactions    transactions[]
}

model transaction_category {
  id              Int          @id @default(autoincrement())
  name            String       @unique  // 'Food & Dining', 'Transport' etc
  created_at      DateTime     @default(now())
  status          Int          @default(1)  // When Prisma sees a field with no default and you don't pass it in the data object, it throws Argument 'status' is missing — it can't guess what value to use.
  transactions    transactions[]
}

model password_reset {
  id              Int        @id @default(autoincrement())
  email           String
  phone           String?
  otp             String
  createdAt       DateTime   @default(now()) @map("created_at")
  expiresAt       DateTime   @map("expires_at")
}

model group {
  id              Int        @id @default(autoincrement())
  name            String
  user_id         Int
  createdAt       DateTime   @default(now()) @map("created_at")
  createdBy       Int        @map("created_by")
  updatedAt       DateTime   @updatedAt  @map("updated_at")
  updatedBy       Int        @map("updated_by")
  status          Int        @default(1)

  user            user       @relation(fields: [user_id], references: [id])
  transactions    group_transaction[]
}

model group_transaction {
  id              Int          @id @default(autoincrement())
  group_id        Int
  transaction_id  Int
  createdAt       DateTime     @default(now()) @map("created_at")
  createdBy       Int          @map("created_by")

  group           group        @relation(fields: [group_id], references: [id], onDelete: Cascade)
  transaction    transactions  @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@unique([group_id, transaction_id])
}
# Database
DATABASE_URL=postgresql://user:password@host:5432/budgetwise

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# SES
SES_FROM_EMAIL=your_verified_email@example.com
EMAIL_USER=your_verified_email@example.com

# SQS
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your_account_id/your_queue_name

# App
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PORT=5000